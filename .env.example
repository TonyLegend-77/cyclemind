# Optional: only needed if you want the backend to have its own default
# Bitget account for testing. Most account-specific calls will use keys
# submitted by the user through the frontend instead.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# Used to encrypt any stored user credentials — generate a random string
SECRET_KEY=change-this-to-a-random-string

# Set this to your deployed frontend URL once live (e.g. https://cyclemind.vercel.app)
FRONTEND_ORIGIN=*
